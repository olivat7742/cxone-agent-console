# Production CXone OIDC (PKCE) config, used by `vite build` for the GitHub Pages deploy.
#
# These are NOT secrets: PKCE is a public-client flow, so client_id and hostname
# are expected to ship in the public bundle (see .env.example). This file is
# committed on purpose so the GitHub Actions build is reproducible.
#
# The redirect URI below MUST be registered EXACTLY in the CXone app registration.

VITE_CXONE_HOSTNAME=https://cxone.niceincontact.com
VITE_CXONE_CLIENT_ID=9798af6c-eab0-4868-a291-198db25988ac
VITE_CXONE_REDIRECT_URI=https://olivat7742.github.io/cxone-agent-console/

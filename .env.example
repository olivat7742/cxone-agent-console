# CXone OIDC (PKCE) configuration
#
# Copy this file to ".env" and fill in the values from your CXone application
# registration. None of these are secrets (PKCE is a public-client flow), but
# .env is gitignored anyway so the repo stays portable.
#
# IMPORTANT: Vite only reads .env at startup. Restart "npm run dev" after edits.

# Your CXone host for your region (NA1). Confirm the exact host in the
# Developer Portal / app registration, e.g. https://cxone.niceincontact.com
VITE_CXONE_HOSTNAME=

# The client_id generated when you register the application in CXone.
VITE_CXONE_CLIENT_ID=

# Must EXACTLY match the redirect URI configured in your app registration.
# For local development this is the dev server callback URL.
VITE_CXONE_REDIRECT_URI=http://localhost:5173/callback
